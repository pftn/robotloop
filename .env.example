# MinIO / S3
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=robotloop-data
# 设备上传原始包（.mcap/.bag）的独立 bucket，唯一配置 bucket notification
S3_RAW_BUCKET=robotloop-raw

# Kafka
KAFKA_BOOTSTRAP=kafka:9092
KAFKA_ADVERTISED_LISTENERS=PLAINTEXT://kafka:9092

# Zookeeper
ZOOKEEPER_CONNECT=zookeeper:2181

# 模型 API
MODEL_API_URL=http://model-api:9002

# Zilliz Cloud (Milvus)
MILVUS_URI=https://in03-ccb5331871341cd.serverless.ali-cn-hangzhou.cloud.zilliz.com.cn
MILVUS_TOKEN=your-zilliz-api-key

# Iceberg
ICEBERG_CATALOG_URI=http://iceberg-rest:8181
ICEBERG_TABLE=robotloop.scenes_meta
ICEBERG_EPISODES_TABLE=robotloop.episodes

# LanceDB 路径
LANCE_PATH=/tmp/lance

# 设备模拟
SIMULATE_NETWORK_ISSUES=false

# HuggingFace 镜像（公开数据集下载）
HF_ENDPOINT=https://hf-mirror.com

# Ray Worker Prometheus 指标端口
METRICS_PORT=9100