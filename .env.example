# SkyLoop Demo 环境变量模板
# 复制此文件为 .env 并根据需要修改

# ---------- 对象存储 (MinIO / S3) ----------
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=robotloop-data

# ---------- PostgreSQL ----------
PG_HOST=postgres
PG_PORT=5432
PG_USER=robotloop
PG_PASSWORD=robotloop
PG_DB=robotloop

# ---------- Kafka ----------
KAFKA_BOOTSTRAP=kafka:9092

# ---------- 设备模拟器 ----------
SIMULATE_NETWORK_ISSUES=true

# ---------- API 服务 ----------
API_PORT=8000